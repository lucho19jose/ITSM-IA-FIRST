# URL del API backend para la app móvil
# =====================================================
# IMPORTANTE: Configura según tu entorno!
#
# EMULADOR Android:
#   VITE_API_URL=http://10.0.2.2:8000/api/v1
#
# DISPOSITIVO FÍSICO (obtén tu IP con 'ipconfig'):
#   VITE_API_URL=http://192.168.80.6:8000/api/v1
#   Ejemplo: VITE_API_URL=http://192.168.1.100:8000/api/v1
#
# PRODUCCIÓN (servidor remoto):
#   VITE_API_URL=https://autoservice.sigatics.com/api/v1
#
# =====================================================
# Si usas dispositivo físico, descomenta y ajusta la siguiente línea:
# VITE_API_URL=http://192.168.80.6:8000/api/v1

# Para emulador:
# VITE_API_URL=http://10.0.2.2:8000/api/v1

# Producción (servidor remoto):
VITE_API_URL=https://autoservice.sigatics.com/api/v1
